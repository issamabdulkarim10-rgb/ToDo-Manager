<Window x:Class="ToDo_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ViewModel;assembly=ViewModel"
        Title="MainWindow" Height="450" Width="800">

    <Window.DataContext>
        <vm:VMMainWindow/>
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="ToDo Manager" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Margin="5">
                <TextBlock Text="Offen:" FontWeight="Bold"/>
                <ListBox ItemsSource="{Binding OffeneAufgaben}"
                         SelectedItem="{Binding SelectedToDo}"
                         DisplayMemberPath="Titel"
                         Height="120"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="Erledigt:" FontWeight="Bold"/>
                <ListBox ItemsSource="{Binding ErledigteAufgaben}"
                         SelectedItem="{Binding SelectedToDo}"
                         DisplayMemberPath="Titel"
                         Height="120"/>
            </StackPanel>
        </Grid>

        
        <StackPanel Grid.Row="2" Margin="0,10" DataContext="{Binding SelectedToDo}">
            <TextBlock Text="Details:" FontWeight="Bold"/>
            <TextBox Text="{Binding Titel, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
            <TextBox Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" Margin="0,5"/>
            <DatePicker SelectedDate="{Binding Faelligkeit}" Margin="0,5"/>

            <Button Content="Als erledigt markieren"
                    Command="{Binding DataContext.ButtonAlsErledigt, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Width="150"
                    Margin="0,5"/>
        </StackPanel>

        
        <StackPanel Grid.Row="3" VerticalAlignment="Bottom">
            <TextBlock Text="Neues Todo:" FontWeight="Bold"/>
            <TextBox Text="{Binding NeuerTitel, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
            <TextBox Text="{Binding NeuerPriority, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>
            <DatePicker SelectedDate="{Binding NeuerFaelligkeit}" Margin="0,2"/>

            <Button Content="Hinzufügen"
                    Command="{Binding ButtonHinzufuegen}"
                    CommandParameter="{Binding}"
                    Width="120"
                    Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>